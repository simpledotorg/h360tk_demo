HEART360TK_VERSION=0.3.6
POSTGRES_HOST=postgres
POSTGRES_DB=heart360tk_database

# FTP passive mode: must match the host clients use in ftp://HOST:2121 (see docker-compose sftpgo).
# Local only: 127.0.0.1. Same host for dev + LAN clients: set to this machine's LAN IP and use that in URLs.
# Internet: set to the server's public IP (and open 2121 + 50000-50100 on the firewall / NAT).
FTP_PASSIVE_IP=127.0.0.1
